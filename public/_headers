/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://accounts.google.com https://apis.google.com; connect-src 'self' https://*.googleapis.com https://apis.google.com https://accounts.google.com https://oauth2.googleapis.com; img-src 'self' blob: data: https://*.googleusercontent.com https://*.gstatic.com; style-src 'self' 'unsafe-inline'; frame-src 'self' https://accounts.google.com https://docs.google.com; form-action 'self' https://accounts.google.com; base-uri 'self'
